{
  "version": "2.0",
  "description": "RightLayout comprehensive real-world test cases",
  "single_words": {
    "description": "Basic single word corrections",
    "cases": [
      {
        "input": "ghbdtn",
        "expected": "привет",
        "desc": "привет"
      },
      {
        "input": "ntrcn",
        "expected": "текст",
        "desc": "текст"
      },
      {
        "input": "ckjdf",
        "expected": "слова",
        "desc": "слова"
      },
      {
        "input": "vbh",
        "expected": "мир",
        "desc": "мир"
      },
      {
        "input": "rjl",
        "expected": "код",
        "desc": "код"
      },
      {
        "input": "ghbdtnbr",
        "expected": "приветик",
        "desc": "приветик (diminutive)"
      },
      {
        "input": "cgfcb,j",
        "expected": "спасибо",
        "desc": "спасибо"
      },
      {
        "input": "ljhjuf",
        "expected": "дорога",
        "desc": "дорога"
      },
      {
        "input": "Ghbdtn",
        "expected": "Привет",
        "desc": "Capitalization preserved (leading uppercase)"
      },
      {
        "input": "GHBDTN",
        "expected": "ПРИВЕТ",
        "desc": "ALL CAPS preserved"
      },
      {
        "input": "руддщ",
        "expected": "hello",
        "desc": "hello typed on Russian (PC/Mac) layout → EN"
      },
      {
        "input": "Руддщ",
        "expected": "Hello",
        "desc": "Hello typed on Russian layout with capitalization"
      },
      {
        "input": "фыв",
        "expected": "asd",
        "desc": "asd typed on Russian layout (home row)"
      },
      {
        "input": "челло",
        "expected": "hello",
        "desc": "hello typed on Russian Phonetic layout → EN",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russian_phonetic",
            "he": "hebrew"
          }
        }
      },
      {
        "input": "akuo",
        "expected": "שלום",
        "desc": "שלום typed on EN layout (Hebrew Mac/PC)"
      },
      {
        "input": "akuo",
        "expected": "שלום",
        "desc": "שלום typed on EN layout (Hebrew PC variant)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew_pc"
          }
        }
      },
      {
        "input": "wlvM",
        "expected": "שלום",
        "desc": "שלום typed on EN layout (Hebrew QWERTY)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew_qwerty"
          }
        }
      },
      {
        "input": "יקךךם",
        "expected": "hello",
        "desc": "hello typed on Hebrew Mac/PC layout → EN"
      },
      {
        "input": "יקךךם",
        "expected": "hello",
        "desc": "hello typed on Hebrew PC layout → EN (explicit variant)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew_pc"
          }
        }
      },
      {
        "input": "העללו",
        "expected": "hello",
        "desc": "hello typed on Hebrew QWERTY layout → EN",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew_qwerty"
          }
        }
      },
      {
        "input": "עינגאמ",
        "expected": "привет",
        "desc": "привет typed on Hebrew Mac/PC layout → RU"
      },
      {
        "input": "גהבדתנ",
        "expected": "привет",
        "desc": "привет typed on Hebrew QWERTY layout → RU",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew_qwerty"
          }
        }
      },
      {
        "input": "флгщ",
        "expected": "שלום",
        "desc": "שלום typed on Russian layout → HE"
      }
    ]
  },
  "comma_period_single_words": {
    "description": "Single words with comma/period (б/ю mapping)",
    "cases": [
      {
        "input": "hf,jnftn",
        "expected": "работает",
        "desc": "работает"
      },
      {
        "input": "k.,k.",
        "expected": "люблю",
        "desc": "люблю"
      },
      {
        "input": ",tp",
        "expected": "без",
        "desc": "без"
      },
      {
        "input": ",ele",
        "expected": "буду",
        "desc": "буду"
      },
      {
        "input": "j,",
        "expected": "об",
        "desc": "об"
      }
    ]
  },
  "real_paragraphs": {
    "description": "Real multi-sentence paragraphs as people actually type",
    "cases": [
      {
        "input": "ghbdtn! rfr ltkf? lfyyj yt dbltk ntyz? ult ns ,sk? z pdjybk nt,t dxthf? yj ns yt jndtnbk",
        "expected": "привет! как дела? давно не видел тебя. где ты был? я звонил тебе вчера, но ты не ответил",
        "desc": "Casual chat with multiple sentences and punctuation"
      },
      {
        "input": "gj;fkeqcnf? jnghfdmnt vyt ljrevtyn lj rjywf lyz? 'nj jxtym df;yj lkz yfituj ghjtrna? ,tp ytuj vs yt cvj;tv ghjljk;bnm hf,jne",
        "expected": "пожалуйста, отправьте мне документ до конца дня. это очень важно для нашего проекта. без него мы не сможем продолжить работу",
        "desc": "Work email - formal request"
      },
      {
        "input": "z yt vjue gjyznm? gjxtve 'nj yt hf,jnftn? vs ghjdthbkb dct yfcnhjqrb? gthtpfuhepmkb cthdth? yj ghjuktvf jcnftncz",
        "expected": "я не могу понять, почему это не работает. мы проверили все настройки, перезагрузили сервер, но проблема остается",
        "desc": "Tech support frustration"
      },
      {
        "input": "pfdhf vs blv d rbyjntfnh? [jxtim gjqnb c yfvb? abkmv yfxbyftncz d 8 dtxthf? yt jpflfq",
        "expected": "завтра мы идем в кинотеатр. хочешь пойти с нами? фильм начинается в 8 вечера. не опаздай",
        "desc": "Casual invitation with time"
      },
      {
        "input": "ljhjufz? c lytv hj;ltybz! ;tkf. nt,t cxfcnmz b pljhjdmz? gentq ,eltn vyjuj? yj dct ,eltn [jhjij",
        "expected": "дорогая, с днем рождения! желаю тебе счастья и здоровья. пусть будет много, но все будет хорошо",
        "desc": "Birthday greeting"
      },
      {
        "input": "dcnhtxf pfdnhf d 14^30? yfgjvyb vyt gj;fkeqcnf/",
        "expected": "встреча завтра в 14:30, напомни мне пожалуйста.",
        "desc": "Meeting scheduling with time (RU-PC punctuation)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew"
          }
        }
      },
      {
        "input": "z gjcvjnhtk kjub — nfv jib,rf^ yt elfkjcm cj[hfybnm afqk/",
        "expected": "я посмотрел логи — там ошибка: не удалось сохранить файл.",
        "desc": "Debugging sentence with em dash + colon (RU-PC punctuation)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew"
          }
        }
      },
      {
        "input": "lfdfq cjpdjybvcz pfdnhf enhjv? e vtyz tcnm gfhf djghjcjd/",
        "expected": "давай созвонимся завтра утром, у меня есть пара вопросов.",
        "desc": "Short planning sentence (RU-PC punctuation)",
        "settings": {
          "activeLayouts": {
            "en": "us",
            "ru": "russianwin",
            "he": "hebrew"
          }
        }
      }
    ]
  },
  "multiline_realistic": {
    "description": "Multi-line text as in real documents",
    "cases": [
      {
        "input": "pfujkjdjr\n\ngthdst cnhjrb ntrcnf? rjnjhst jxtym df;ys?\ndnjhst cnhjrb ntrcnf? rjnjhst njt df;ys?\n\npfrk.xtybt",
        "expected": "заголовок\n\nпервые строки текста, которые очень важны.\nвторые строки текста, которые тоже важны.\n\nзаключение",
        "desc": "Document with header, paragraphs, conclusion"
      },
      {
        "input": "cgbcjr gjregr:\n- [kt,\n- vjkjrj\n- zqwf\n- vfckj\n\nbnjuj: 500 he,",
        "expected": "список покупок:\n- хлеб\n- молоко\n- яйца\n- масло\n\nитого: 500 руб",
        "desc": "Shopping list with bullets and total"
      }
    ]
  },
  "context_boost_hard": {
    "description": "Hard cases where first word is very ambiguous",
    "cases": [
      {
        "words": [
          "z",
          "nt,z",
          "k.,k."
        ],
        "expected_final": "я тебя люблю",
        "desc": "я тебя люблю - classic"
      },
      {
        "words": [
          "d",
          "'njv",
          "ujle",
          "vs",
          "pfgecnbkb",
          "ghjtrn"
        ],
        "expected_final": "в этом году мы запустили проект",
        "desc": "в этом году... - preposition + long phrase"
      },
      {
        "words": [
          "f",
          "ns",
          "xnj",
          "levftim"
        ],
        "expected_final": "а ты что думаешь",
        "desc": "а ты что думаешь - starts with single letter"
      },
      {
        "words": [
          "j",
          "xtv",
          "ds",
          "ujdjhbnt"
        ],
        "expected_final": "о чем вы говорите",
        "desc": "о чем вы говорите - question starting with о"
      },
      {
        "words": [
          "e",
          "vtyz",
          "tcnm",
          "bltz"
        ],
        "expected_final": "у меня есть идея",
        "desc": "у меня есть идея - starts with у"
      },
      {
        "words": [
          "r",
          "cj;fktyb.",
          "'nj",
          "ytdjpvj;yj"
        ],
        "expected_final": "к сожалению это невозможно",
        "desc": "к сожалению - formal phrase"
      },
      {
        "words": [
          "yj",
          "'nj",
          "yt",
          "njxyj"
        ],
        "expected_final": "но это не точно",
        "desc": "но это не точно - meme phrase"
      },
      {
        "words": [
          "d",
          "'njq",
          "ntvt",
          "vs",
          "e;t",
          ",skb"
        ],
        "expected_final": "в этой теме мы уже были",
        "desc": "Single-letter preposition + confirmation later"
      },
      {
        "words": [
          "f",
          "'nj",
          "djj,ot",
          "yjhvfkmyj"
        ],
        "expected_final": "а это вообще нормально",
        "desc": "Starts with 'а' and mixes short/long words"
      },
      {
        "words": [
          "e",
          "vtyz",
          "ytn",
          "dhtvtyb"
        ],
        "expected_final": "у меня нет времени",
        "desc": "Short first word + common phrase"
      }
    ]
  },
